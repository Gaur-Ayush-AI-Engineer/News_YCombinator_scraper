HN_BASE_URL=https://hacker-news.firebaseio.com/v0
STORY_LIMIT=10
MAX_COMMENTS_PER_STORY=100
REPLY_DEPTH=2
CONCURRENCY=25
MAX_CONTENT_CHARS=25000
LOG_LEVEL=INFO

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
LLM_VERIFY_ENABLED=false
LLM_WEB_SEARCH_MODE=suspicious
LLM_MAX_INPUT_CHARS=8000
LLM_WEB_SEARCH_TOOL=web_search

SENTIMENT_ENABLED=true
SENTIMENT_MODEL=gpt-5.4-nano
SENTIMENT_TOP_N=5
SENTIMENT_MAX_COMMENTS=100
SENTIMENT_MAX_COMMENT_CHARS=1200

SUMMARY_ENABLED=true
SUMMARY_MODEL=gpt-5.4-nano
SUMMARY_MAX_INPUT_CHARS=12000

AUTO_LLM_VERIFY_ON_QUALITY_ISSUE=true
